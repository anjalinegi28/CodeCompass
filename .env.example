# Which LLM provider to use for answering + eval: openai | gemini | claude
LLM_PROVIDER=openai

# Provide the key for whichever provider(s) you plan to use
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=

# Embedding model (any Sentence-Transformers model name)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Vector store backend: chroma | faiss
VECTOR_STORE=chroma
CHROMA_PERSIST_DIR=.codecompass/chroma_db
FAISS_INDEX_PATH=.codecompass/faiss_index

# Chunking
CHUNK_SIZE=800
CHUNK_OVERLAP=120

# Eval gate threshold (0.0 - 1.0). CI fails if any RAGAS score drops below this.
EVAL_THRESHOLD=0.70

# MLflow tracking
MLFLOW_TRACKING_URI=./.codecompass/mlruns
MLFLOW_EXPERIMENT_NAME=codecompass-eval
